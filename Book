public class Book {
     private int id;
     private String title;
     private String genre;
     // 构造方法
     public Book(int id, String title, String genre) {
         this.id = id;
         this.title = title;
         this.genre = genre;
     }
     // Getter 方法
     public int getId() {
         return id;
     }
     public String getTitle() {
         return title;
     }
     public String getGenre() {
         return genre;
     }
     // 重写toString方便打印
     @Override
     public String toString() {
         return "Book{id=" + id + ", title='" + title + "', genre='" + genre + "'}";
     }
 }
